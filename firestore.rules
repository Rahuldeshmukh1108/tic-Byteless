rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeviceOwner(deviceId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/devices/$(deviceId));
    }

    // Users collection - each user can only access their own document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      
      // User's devices subcollection
      match /devices/{deviceId} {
        allow read, write: if request.auth.uid == userId;
      }
      
      // User's alerts subcollection
      match /alerts/{alertId} {
        allow read, write: if request.auth.uid == userId;
      }
      
      // User's automation rules subcollection
      match /automation/{ruleId} {
        allow read, write: if request.auth.uid == userId;
      }

      // User settings
      match /settings/{document=**} {
        allow read, write: if request.auth.uid == userId;
      }

      // User dashboard metrics
      match /metrics/{document=**} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    // Devices collection - only accessible by the owning authenticated user
    match /devices/{deviceId} {
      allow read, write: if isDeviceOwner(deviceId);
      
      // Live data subcollection - device owner only
      match /live/{document=**} {
        allow read, write: if isDeviceOwner(deviceId);
      }

      // Historical readings subcollection
      match /readings/{readingId} {
        allow read, create: if isDeviceOwner(deviceId);
      }

      // Automation config under devices
      match /automation/{document=**} {
        allow read, write: if isDeviceOwner(deviceId);
      }
    }
    
    // Analytics collection - only readable by authenticated users
    match /analytics/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
