rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - each user can only access their own document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      
      // User's devices subcollection
      match /devices/{deviceId} {
        allow read, write: if request.auth.uid == userId;
      }
      
      // User's alerts subcollection
      match /alerts/{alertId} {
        allow read, write: if request.auth.uid == userId;
      }
      
      // User's automation rules subcollection
      match /automation/{ruleId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    // Devices collection - accessible by authenticated users and devices
    match /devices/{deviceId} {
      // Allow read/write for authenticated users
      allow read, write: if request.auth != null;
      
      // Live data subcollection
      match /live/{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null || resource == null;
      }
      
      // Historical readings subcollection
      match /readings/{readingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null || request.auth == null;
      }
    }
    
    // Analytics collection - only readable by authenticated users
    match /analytics/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
